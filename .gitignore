# Node / pnpm
node_modules/
.pnpm-store/
dist/
build/
out/
.vite/

# Electron packaging
release/
*.exe.blockmap
ui/dist-electron/

# Python
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.ruff_cache/
.mypy_cache/
.hypothesis/
.venv/
venv/
.uv-cache/
*.egg-info/
.coverage
.coverage.*
htmlcov/
coverage.xml

# Local data
~/.cybersecurity-assessor/
data/
*.sqlite
*.sqlite3
*.db

# OS / IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp

# Build cache / runtime logs (transient, change on every build/run)
*.tsbuildinfo
*.log

# CUI safety — never commit workbooks, evidence, or extracted text
*.xlsx
*.xlsm
*.docx
*.pptx
*.pdf
*.ckl
*.cklb
*.nessus
extracted_text/

# Exception: bundled scrubbed eMASS RMF_POAM template ships with the package
# so the UI never needs to ask the user to locate an eMASS export file. The
# template contains no CUI — header rows + sentinel values only.
!backend/cybersecurity_assessor/poam/templates/
!backend/cybersecurity_assessor/poam/templates/*.xlsx

# Exception: synthetic demo bundle — fully scrubbed "Example System" / "Example
# Program" artifacts for end-to-end testing. NO CUI; all generated by the
# demo/_build_demo_*.py scripts. Scoped per-folder so nothing outside these
# synthetic folders is ever un-ignored.
!demo/cci_list/**
!demo/ccis/**
!demo/configs/**
!demo/crm/**
!demo/policies/**
!demo/psc/**
!demo/scans/**
!demo/stigs/**
!demo/workbooks/**

# Defense in depth: the REAL-program bundle under demo/example_system/ is CUI.
# It has its own nested .gitignore blocking everything but its README; re-block
# it here too so no parent exception can ever sweep it into git.
demo/example_system/**
!demo/example_system/README.md
!demo/example_system/.gitignore

evidence_cache/

# Env
.env
.env.local
.env.*.local

# Secrets
*.key
*.pem

# Local scratch / one-off baselines
tmp/
.leverA_backup/
_eval_current_vs_gold.json

# Vendored Tesseract OCR binary (~164MB) — bundled into the installer at build
# time but NOT committed: it's a large third-party binary, re-acquirable from
# the UB-Mannheim release. backend/vendor/README.md documents how to re-vendor
# it before packaging. Keep the README tracked; ignore the binary tree.
backend/vendor/tesseract/
backend/vendor/_tess_dl/
!backend/vendor/README.md
