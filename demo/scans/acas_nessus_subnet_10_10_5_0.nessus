        <tag name="HOST_END">Wed May 20 09:41:08 2026</tag>
      </HostProperties>
      <ReportItem port="0" svc_name="general" protocol="tcp" severity="0" pluginID="19506" pluginName="Nessus Scan Information" pluginFamily="Settings">
        <description>This plugin displays information about the Nessus scan.</description>
        <plugin_output>Credentialed scan: yes
Scanner edition: Tenable.sc / ACAS
Scan policy: Example System Credentialed Windows
Scan duration: 2334 sec</plugin_output>
        <risk_factor>None</risk_factor>
      </ReportItem>
      <ReportItem port="0" svc_name="general" protocol="tcp" severity="2" pluginID="63155" pluginName="Microsoft Windows Unquoted Service Path Enumeration" pluginFamily="Windows">
        <description>The remote Windows host has at least one service installed that uses an unquoted service path, which contains at least one whitespace.</description>
        <solution>Ensure that any services that contain a space in the path enclose the path in quotes.</solution>
        <risk_factor>Medium</risk_factor>
        <cvss3_base_score>7.8</cvss3_base_score>
        <plugin_output>One or more services installed have an unquoted service path:
  Service Name : LegacyBackupAgent
  Service Path : C:\Program Files\Acme Backup\backup agent.exe</plugin_output>
        <see_also>https://learn.microsoft.com/en-us/windows/win32/services/service-trustees</see_also>
      </ReportItem>
      <ReportItem port="445" svc_name="cifs" protocol="tcp" severity="3" pluginID="178102" pluginName="Microsoft Windows Telnet Client Installed" pluginFamily="Windows">
        <description>The Telnet Client optional feature is installed on the remote Windows host. Telnet transmits data, including credentials, in cleartext.</description>
        <solution>Remove the Telnet Client optional feature via Server Manager or DISM.</solution>
        <risk_factor>High</risk_factor>
        <cvss3_base_score>8.1</cvss3_base_score>
        <cve>CVE-2025-21311</cve>
        <plugin_output>Optional Feature : TelnetClient
State            : Enabled
Install Source   : DISM</plugin_output>
      </ReportItem>
      <ReportItem port="3389" svc_name="msrdp" protocol="tcp" severity="2" pluginID="58453" pluginName="Terminal Services Doesn't Use Network Level Authentication (NLA) Only" pluginFamily="Windows">
        <description>The remote Terminal Services is not configured to use NLA only, exposing the service to man-in-the-middle attacks.</description>
        <solution>Enable Network Level Authentication on the RDP service.</solution>
        <risk_factor>Medium</risk_factor>
        <cvss3_base_score>5.4</cvss3_base_score>
      </ReportItem>
    </ReportHost>
