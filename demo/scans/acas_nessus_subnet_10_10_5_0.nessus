      <ReportItem port="22" svc_name="ssh" protocol="tcp" severity="1" pluginID="153953" pluginName="SSH Server CBC Mode Ciphers Enabled" pluginFamily="Misc." >
        <description>The SSH server is configured to support Cipher Block Chaining (CBC) encryption. This may allow attackers to recover plaintext from ciphertext.</description>
        <solution>Disable CBC-mode ciphers and use CTR or AEAD modes.</solution>
        <risk_factor>Low</risk_factor>
        <cvss3_base_score>3.7</cvss3_base_score>
        <plugin_output>The following client-to-server CBC ciphers are supported:
  aes128-cbc
  aes256-cbc</plugin_output>
      </ReportItem>
      <ReportItem port="0" svc_name="general" protocol="tcp" severity="3" pluginID="195231" pluginName="RHEL 9 : kernel security update (RHSA-2026:1187)" pluginFamily="Red Hat Local Security Checks">
        <description>An update for kernel is available that addresses CVE-2026-0117, a use-after-free in the netfilter subsystem allowing local privilege escalation.</description>
        <solution>Run 'dnf update kernel' and reboot.</solution>
        <risk_factor>High</risk_factor>
        <cvss3_base_score>7.8</cvss3_base_score>
        <cve>CVE-2026-0117</cve>
        <plugin_output>Installed kernel: 5.14.0-362.18.1.el9_3
Fixed kernel    : 5.14.0-362.24.2.el9_3</plugin_output>
      </ReportItem>
      <ReportItem port="0" svc_name="general" protocol="tcp" severity="2" pluginID="151502" pluginName="RHEL 9 : /var/log mount point not separate partition" pluginFamily="Red Hat Local Security Checks">
        <description>STIG RHEL-09-211045 requires /var/log on a separate filesystem to prevent log expansion from filling the root partition.</description>
        <solution>Migrate /var/log to its own LVM volume.</solution>
        <risk_factor>Medium</risk_factor>
        <cvss3_base_score>5.5</cvss3_base_score>
        <plugin_output>findmnt /var/log returned empty -- /var/log is part of / (root) partition.</plugin_output>
      </ReportItem>
    </ReportHost>
