      <ReportItem port="443" svc_name="https" protocol="tcp" severity="2" pluginID="51192" pluginName="SSL Certificate Cannot Be Trusted" pluginFamily="General">
        <description>The server's X.509 certificate cannot be trusted: chains to a CA that is not in the trust store.</description>
        <solution>Reissue the certificate from the Example System internal CA chained to the DoD root.</solution>
